{
  "name": "hivemind-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --max-warnings=168",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:staged": "eslint --max-warnings=0",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "playwright test integration.spec.ts",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../shared/openapi/full.json -o src/types/api.gen.ts",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .husky',{cwd:'..'})}catch(e){}\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/x": "^2.3.0",
    "@ant-design/x-sdk": "^2.3.0",
    "@ant-design/x-skill": "^2.3.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "antd": "^6.3.0",
    "axios": "^1.13.5",
    "d3-force": "^3.0.0",
    "force-graph": "^1.51.1",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.0",
    "allure-playwright": "^3.0.0",
    "allure-vitest": "^3.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "msw": "^2.13.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.11",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --max-warnings=50"
  }
}
