    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "antd": "^6.3.0",
    "axios": "^1.13.5",
    "d3-force": "^3.0.0",
    "force-graph": "^1.51.1",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.0",
