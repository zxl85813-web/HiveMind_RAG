{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "e2e/**/*.spec.ts",
    "e2e/**/*.ts",
    "tests/e2e/**/*.spec.ts",
    "tests/e2e/**/*.ts",
    "playwright.config.ts"
  ]
}
