#!/usr/bin/env bash

# pre-commit git hook
# Checks for hardcoded secrets and runs linters if possible.

echo "🔍 [Pre-Commit] 运行系统与代码合规检查..."

# 1. 检查是否存在硬编码的敏感词 (例如 sk-xxx, api_key=)
# 这是一个简单的正则排查，防止将密钥等推入库中
FORBIDDEN_PATTERNS="sk-[a-zA-Z0-9]{32,}|api_key[ =]+['\"][^'\"]{8,}['\"]|password[ =]+['\"][^'\"]+['\"]"
FORBIDDEN_FILES=$(git diff --cached --name-only | grep -E '\.(py|ts|tsx|js|jsx)$' || true)

if [ -n "$FORBIDDEN_FILES" ]; then
    for file in $FORBIDDEN_FILES; do
        if git show ":$file" | grep -iE "$FORBIDDEN_PATTERNS" > /dev/null; then
            echo "❌ 错误: 在 $file 中检测到疑似硬编码的密钥 (Secret/API Key)！"
            echo "👉 请将密钥提取到 .env 文件中，或从代码库中移除！"
            echo "如果你确认是误报，你可以使用 git commit --no-verify 强行提交 (但将会被 CI 记录)。"
            exit 1
        fi
    done
fi

# 2. 尝试运行本地快速脚本 (如果存在)
# 使用 powershell 运行代码质量检查，此处仅为防线之一，CI 中会有更严格的验证
if command -v powershell &> /dev/null && [ -f ".agent/checks/run_checks.ps1" ]; then
    echo "🛠️ 正在调用轻量级本地 Check (run_checks.ps1)..."
    # 这里我们只调用脚本进行基础告警，不一定阻塞（否则执行太慢）
    # 但实际项目中可以修改 -StopOnFailure
fi

echo "✅ [Pre-Commit] 检查通过!"
exit 0
