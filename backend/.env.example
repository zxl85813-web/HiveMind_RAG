# === App ===
PROJECT_NAME="HiveMind RAG"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]

# === Authentication ===
SECRET_KEY="replace-with-a-real-secret-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Database ===
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DB="hivemind"

# === LLM Provider (SiliconFlow / DeepSeek Flagship) ===
LLM_PROVIDER="siliconflow"
LLM_API_KEY="sk-your-siliconflow-api-key"
LLM_MODEL="deepseek-ai/DeepSeek-V3.2"
LLM_BASE_URL="https://api.siliconflow.cn/v1"

# === Volcengine Ark (OpenAI-compatible) ===
# API endpoint for responses: https://ark.cn-beijing.volces.com/api/v3/responses
ARK_API_KEY="your-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="deepseek-v3-2-251201"

# To switch default LLM to Ark, update these values:
# LLM_PROVIDER="ark"
# LLM_API_KEY="your-ark-api-key"
# LLM_MODEL="deepseek-v3-2-251201"
# LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# === HiveMind Model Routing ===
DEFAULT_CHAT_MODEL="deepseek-ai/DeepSeek-V3.2"
DEFAULT_REASONING_MODEL="kimi-k2.5"

# Tier-specific provider selection
REASONING_PROVIDER="moonshot"
BALANCED_PROVIDER="siliconflow"
FAST_PROVIDER="siliconflow"


# === Logging ===
LOG_LEVEL="INFO"

# === Vector Store ===
VECTOR_STORE_TYPE=chroma

# Elasticsearch Configurations
ES_HOST=127.0.0.1
ES_PORT=9200
ES_API_KEY=your-es-api-key
ES_INDEX_PREFIX=linkrag

# Neo4j Configurations
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Embedding Configurations
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=your-zhipu-api-key
EMBEDDING_DIMS=2048

# Kimi API Configurations
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k
