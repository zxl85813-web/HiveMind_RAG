# === App ===
PROJECT_NAME="HiveMind RAG"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]

# === Authentication ===
SECRET_KEY="replace-with-a-real-secret-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Database ===
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DB="hivemind"

# === LLM Provider (SiliconFlow / DeepSeek Flagship) ===
LLM_PROVIDER="siliconflow"
LLM_API_KEY="sk-your-siliconflow-api-key"
LLM_MODEL="deepseek-ai/DeepSeek-V3.2"
LLM_BASE_URL="https://api.siliconflow.cn/v1"

# === DeepSeek 官方 API (V4 — 推荐用于 Simple/Medium/Complex 层) ===
# V4-Flash: $0.14/M input, $0.028/M cache hit (80% off), $0.28/M output
# V4-Pro:   $1.74/M input, $0.145/M cache hit (92% off), $3.48/M output
# 切换方式: 将下方 DEFAULT_*_MODEL 改为 V4 模型名，并将 LLM_PROVIDER 改为 deepseek
# DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# === Volcengine Ark (OpenAI-compatible) ===
# API endpoint for responses: https://ark.cn-beijing.volces.com/api/v3/responses
ARK_API_KEY="your-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="deepseek-v3-2-251201"

# To switch default LLM to Ark, update these values:
# LLM_PROVIDER="ark"
# LLM_API_KEY="your-ark-api-key"
# LLM_MODEL="deepseek-v3-2-251201"
# LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# === NVIDIA NIM (OpenAI-compatible, Free Tier) ===
# Provider: https://integrate.api.nvidia.com/v1
# Used for: Reasoning Tier — DeepSeek-V4-Pro with chain-of-thought thinking
# Get a free API key at: https://build.nvidia.com/deepseek-ai/deepseek-v4-pro
NVIDIA_API_KEY="nvapi-your-nvidia-api-key"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_REASONING_MODEL="deepseek-ai/deepseek-v4-pro"
NVIDIA_THINKING_ENABLED=true
NVIDIA_REASONING_EFFORT="max"  # low | medium | max

# === HiveMind Model Routing ===
DEFAULT_CHAT_MODEL="deepseek-ai/DeepSeek-V3.2"
DEFAULT_REASONING_MODEL="kimi-k2.5"

# Tier-specific provider selection
REASONING_PROVIDER="moonshot"
BALANCED_PROVIDER="siliconflow"
FAST_PROVIDER="siliconflow"

# === ClawRouter 4-Tier Model Config ===
# Simple/Medium: V4-Flash — 轻量任务，缓存命中后仅 $0.028/M，极低成本
# Complex:       V4-Pro   — 代码生成/分析，缓存命中后 $0.145/M
# Reasoning:     NVIDIA NIM V4-Pro — 推理层，带 chain-of-thought
DEFAULT_SIMPLE_MODEL="deepseek-ai/DeepSeek-V4-Flash"
DEFAULT_MEDIUM_MODEL="deepseek-ai/DeepSeek-V4-Flash"
DEFAULT_COMPLEX_MODEL="deepseek-ai/DeepSeek-V4-Pro"


# === Logging ===
LOG_LEVEL="INFO"

# === Vector Store ===
VECTOR_STORE_TYPE=chroma

# Elasticsearch Configurations
ES_HOST=127.0.0.1
ES_PORT=9200
ES_API_KEY=your-es-api-key
ES_INDEX_PREFIX=linkrag

# Neo4j Configurations
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Embedding Configurations
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=your-zhipu-api-key
EMBEDDING_DIMS=2048

# Kimi API Configurations
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

# GitHub Integration (for PR/Review/Release graph indexing)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO_OWNER=zxl85813-web
GITHUB_REPO_NAME=HiveMind_RAG

# === Harness Feature Flags ===
# 在 Harness UI → Feature Flags → Environments → SDK Keys 中获取
# 未配置时自动降级到上方的 settings 环境变量（零侵入）
# HARNESS_FF_SDK_KEY=sdk-your-harness-ff-sdk-key
